---
import BaseLayout from '../layouts/BaseLayout.astro'
import { name, role, bio, nowItems, social } from '../data/about'
---

<BaseLayout currentPath="/">
  <article>
    <header class="about-header">
      <img class="about-avatar" src="/static/images/avatar.jpg" alt={name} width="56" height="56" />
      <div>
        <h1 class="about-name">{name}</h1>
        <p class="about-role">{role}</p>
        <div class="about-links">
          {
            social.map((link) => (
              <a
                class="about-link"
                href={link.href}
                aria-label={link.label}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
              >
                {link.label === 'GitHub' && (
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                  </svg>
                )}
                {link.label === 'Substack' && (
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.524 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z" />
                  </svg>
                )}
                {link.label === 'Email' && (
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="1" y="3" width="14" height="10" rx="1.5" />
                    <path d="M1 4.5 8 9.5l7-5" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </header>

    {bio.map((p) => <p class="bio-p" set:html={p} />)}

    <div class="now-section">
      <p class="now-label">Now</p>
      <ul class="now-list">
        {
          nowItems.map((item) => (
            <li class="now-item">
              <span class="now-arrow">→</span>
              <span class="now-text" set:html={item.text} />
            </li>
          ))
        }
      </ul>
    </div>
  </article>
</BaseLayout>
